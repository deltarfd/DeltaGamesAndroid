<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.deltarfd.deltagamesandroid.presentation.home.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home" />

    <fragment
        android:id="@+id/searchFragment"
        android:name="com.deltarfd.deltagamesandroid.presentation.search.SearchFragment"
        android:label="Search"
        tools:layout="@layout/fragment_search" />

    <include-dynamic
        android:id="@+id/nav_favorite"
        app:graphResName="nav_favorite"
        app:moduleName="favorite" />

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.deltarfd.deltagamesandroid.presentation.profile.ProfileFragment"
        android:label="Profile"
        tools:layout="@layout/fragment_profile" />

</navigation>
