<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.DeltaGames" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryVariant">@color/colorPrimaryDark</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorSecondary">@color/colorSecondary</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:colorBackground">@color/colorBackground</item>
        <item name="colorSurface">@color/colorSurface</item>
        <item name="colorOnSurface">@color/colorTextPrimary</item>
        <item name="android:statusBarColor">@color/colorBackground</item>
        <item name="android:navigationBarColor">@color/colorNavBar</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:textColor">@color/colorTextPrimary</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <!--
        Extends Theme.DeltaGames (AppCompat-compatible).
        windowSplashScreen* attributes configure the Android 12+ system splash screen
        WITHOUT requiring Theme.SplashScreen as parent (which was crashing AppCompatActivity).
    -->
    <style name="Theme.DeltaGames.Splash" parent="Theme.DeltaGames">
        <item name="android:windowBackground">@color/colorBackground</item>
        <!-- Android 12+ splash screen attributes (ignored on older Android, no crash) -->
        <item name="windowSplashScreenBackground">@color/colorBackground</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_icon</item>
        <item name="windowSplashScreenIconBackgroundColor">@android:color/transparent</item>
        <item name="postSplashScreenTheme">@style/Theme.DeltaGames</item>
    </style>

    <!--
        Used by MainActivity only.
        Sets windowAnimationStyle=@null so the system-triggered locale recreation
        (via LocaleManager on API 33+) produces zero visual flash/blink.
        DetailActivity is unaffected and retains its own slide animations.
    -->
    <style name="Theme.DeltaGames.Main" parent="Theme.DeltaGames">
        <item name="android:windowAnimationStyle">@null</item>
        <item name="android:windowBackground">@color/colorBackground</item>
    </style>

    <!-- Dialog Style (dark themed) -->
    <style name="DeltaGames.Dialog" parent="ThemeOverlay.MaterialComponents.Dialog.Alert">
        <item name="android:background">@color/colorCard</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textColorPrimary">@color/white</item>
        <item name="colorAccent">@color/colorPrimary</item>
    </style>

    <!-- Card Style -->
    <style name="DeltaGames.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/colorCard</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">0dp</item>
        <item name="android:foreground">?attr/selectableItemBackground</item>
    </style>

    <!-- Bottom Navigation -->
    <style name="DeltaGames.BottomNav" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="android:background">@color/colorNavBar</item>
        <item name="itemIconTint">@drawable/bottom_nav_selector</item>
        <item name="itemTextColor">@drawable/bottom_nav_selector</item>
        <item name="elevation">8dp</item>
    </style>

    <!-- Text Styles -->
    <style name="DeltaGames.TextAppearance.Title" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textColor">@color/colorTextPrimary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="DeltaGames.TextAppearance.SectionHeader" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">18sp</item>
    </style>

    <!-- Button Styles -->
    <style name="DeltaGames.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/colorPrimary</item>
        <item name="android:textColor">@color/black</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <!-- Title Text Appearances for Collapsing Toolbar (set inline via app:) -->
    <style name="DeltaGames.ExpandedTitle" parent="TextAppearance.MaterialComponents.Headline5">
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
        <item name="android:shadowColor">@color/black</item>
        <item name="android:shadowDx">1</item>
        <item name="android:shadowDy">1</item>
        <item name="android:shadowRadius">4</item>
    </style>

    <style name="DeltaGames.CollapsedTitle" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>